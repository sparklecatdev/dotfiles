#!/usr/bin/env bash
set -euo pipefail

SERVER_FILE="/etc/mullvad-vpnns-server"
TMP_DIR="/run/wireguard"
TMP="$TMP_DIR/current-mullvad.conf"

mkdir -p "$TMP_DIR"
chmod 700 "$TMP_DIR"

SERVER="$(cat "$SERVER_FILE")"
SRC="/etc/wireguard/${SERVER}.conf"

if [[ ! -f "$SRC" ]]; then
    echo "Missing config: $SRC"
    exit 1
fi

wg-quick down "$TMP" 2>/dev/null || true

sed '/^DNS[[:space:]]*=/s/^/#/' "$SRC" > "$TMP"
chmod 600 "$TMP"

wg-quick up "$TMP"
